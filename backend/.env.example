# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL ───────────────────────────────────────
DATABASE_URL=postgres://conectia:conectia@localhost:5432/conectia
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false

# ─── Firebase Admin ───────────────────────────────────
FIREBASE_PROJECT_ID=conectia-ebb79
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@conectia-ebb79.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Webhooks ─────────────────────────────────────────
# WOMPI_EVENTS_SECRET=your_wompi_events_secret
# WOMPI_INTEGRITY_SECRET=your_wompi_integrity_secret

# ─── Logging ──────────────────────────────────────────
LOG_LEVEL=debug
CORS_ORIGIN=*
